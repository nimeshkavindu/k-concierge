{
  "name": "kapruka-ai-agent",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "NEXT_TEST_WASM=1 next dev --webpack",
    "dev:https": "NEXT_TEST_WASM=1 next dev --webpack --experimental-https --experimental-https-key .certs/kapruka-local-key.pem --experimental-https-cert .certs/kapruka-local.pem",
    "build": "NEXT_TEST_WASM=1 next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --pretty false",
    "relay:dev": "tsx relay/server.ts",
    "relay:secure:dev": "VOICE_RELAY_PUBLIC_URL=wss://127.0.0.1:8787 VOICE_RELAY_TLS_KEY=.certs/kapruka-local-key.pem VOICE_RELAY_TLS_CERT=.certs/kapruka-local.pem npm run relay:dev",
    "dev:all": "concurrently -k -n next,relay -c blue,green \"npm run dev\" \"npm run relay:dev\"",
    "dev:secure:all": "concurrently -k -n next,relay -c blue,green \"npm run dev:https\" \"npm run relay:secure:dev\"",
    "relay:build": "tsc -p tsconfig.relay.json",
    "relay:start": "node dist-relay/relay/server.js",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck && npm run test && npm run relay:build && npm run build"
  },
  "dependencies": {
    "eslint-plugin-react": "^7.37.5",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
